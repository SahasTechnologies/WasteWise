---
import BaseLayout from '../components/BaseLayout.astro';
import articlesData from '../data/articles.json';
export const prerender = true;
---

<BaseLayout title="Articles | WasteWise">
    <section class="articles-page-wrapper">
        <div class="articles-header">
            <h1 class="header-title">Articles</h1>
            <p class="header-subtitle">Read information on recycling and video</p>
        </div>

        <div class="articles-list">
            {articlesData.map((item) => (
                item.type === 'article' ? (
                    <div class="card article-card">
                        <div class="article-content">
                            <h2 class="article-title">{item.title}</h2>
                            <p class="article-extract">{item.extract}</p>
                            <a href={item.url} target="_blank" rel="noopener noreferrer" class="visit-btn">
                                Visit Site 
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                    <polyline points="12 5 19 12 12 19"></polyline>
                                </svg>
                            </a>
                        </div>
                    </div>
                ) : (
                    <div class="card video-card">
                        <h2 class="video-title">{item.title}</h2>
                        <div class="video-container">
                            <iframe 
                                src={item.url} 
                                title="YouTube video player" 
                                frameborder="0" 
                                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                                allowfullscreen>
                            </iframe>
                        </div>
                    </div>
                )
            ))}
        </div>
    </section>
</BaseLayout>

<style>
    .articles-page-wrapper {
        width: 100%;
        margin: 0 auto;
        padding: 104px var(--hero-inset) 40px;
        box-sizing: border-box;
    }

    .articles-header {
        text-align: center;
        margin-bottom: 3.5rem;
    }

    .header-title {
        font-size: 3.25rem;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 0.5rem;
        letter-spacing: -0.02em;
        font-family: var(--font-display);
    }

    .header-subtitle {
        font-size: 1.25rem;
        color: var(--ink);
        opacity: 0.7;
        font-weight: 500;
    }

    .articles-list {
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    .card {
        background: var(--glass);
        border: 1px solid var(--glass-border);
        border-radius: 16px;
        padding: 2.5rem;
        box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.05);
    }

    .article-card {
        display: flex;
        flex-direction: column;
    }

    .article-content {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
    }

    .article-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 1rem;
        line-height: 1.3;
    }

    .article-extract {
        font-size: 1.05rem;
        color: var(--ink);
        opacity: 0.8;
        line-height: 1.6;
        margin-bottom: 1.5rem;
        font-weight: 400;
    }

.visit-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: linear-gradient(180deg, var(--green-1), var(--green-2));
        color: #ffffff;
        font-family: var(--font-ui);
        font-weight: 700;
        font-size: 0.95rem;
        padding: 0.6rem 1.25rem;
        border-radius: 9999px;
        text-decoration: none;
        transition: transform 0.2s;
        box-shadow: 0 4px 12px rgba(43, 161, 54, 0.2);
    }

    .visit-btn:hover {
        transform: translateY(-2px);
    }

    .video-card {
        display: flex;
        flex-direction: column;
        align-items: center; /* Center the video title and container */
    }

    .video-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--ink);
        margin-bottom: 1.5rem;
        text-align: center;
    }

    .video-container {
        position: relative;
        width: 100%;
        max-width: 800px; /* Constrain the video width to keep it smaller */
        padding-bottom: min(56.25%, 450px); /* Adjust padding for roughly 16:9 on 800px width */
        height: 0;
        overflow: hidden;
        border-radius: 12px;
        background: #000;
    }

    .video-container iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: 0;
    }

    @media (max-width: 768px) {
        .card {
            padding: 1.5rem;
        }
    }
</style>
