---
import { Globe, MapPin, BookOpen, Search, Map, BarChart3, Target } from '@lucide/astro';
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout title="About | WasteWise">
	<section class="simple-section">
		<h1 class="header-title">About WasteWise</h1>
		<p class="header-subtitle">
			WasteWise helps you recycle correctly, find local drop-off points, and learn simple habits that reduce waste.
		</p>

		<h2 class="section-heading">Our Mission</h2>
		<p class="section-text">
			We believe recycling should be simple and accessible for everyone. WasteWise was created to bridge the gap between 
			good intentions and effective action, providing clear guidance on what can be recycled and where to take it.
		</p>

		<div class="about-grid">
			<div class="about-card">
				<div class="about-card-icon">
					<Globe size={32} />
				</div>
				<h3 class="about-card-title">Environmental Impact</h3>
				<p class="about-card-text">
					Every item recycled correctly helps reduce landfill waste, conserve natural resources, and lower carbon emissions. 
					Small actions create big change when we all participate.
				</p>
			</div>
			<div class="about-card">
				<div class="about-card-icon">
					<MapPin size={32} />
				</div>
				<h3 class="about-card-title">Local Solutions</h3>
				<p class="about-card-text">
					Find nearby recycling centers, drop-off points, and specialized facilities. We connect you with local resources 
					to make recycling convenient and practical.
				</p>
			</div>
			<div class="about-card">
				<div class="about-card-icon">
					<BookOpen size={32} />
				</div>
				<h3 class="about-card-title">Education First</h3>
				<p class="about-card-text">
					Understanding what can and can't be recycled is crucial. Our guides, quizzes, and articles help you become 
					a more informed and effective recycler.
				</p>
			</div>
			<div class="about-card">
				<div class="about-card-icon">
					<Target size={32} />
				</div>
				<h3 class="about-card-title">Clear Goals</h3>
				<p class="about-card-text">
					We establish clear goals for waste reduction, providing consistent tracking and manageable benchmarks for the community to meet over time.
				</p>
			</div>
			<div class="about-card">
				<div class="about-card-icon">
					<BarChart3 size={32} />
				</div>
				<h3 class="about-card-title">Data Driven</h3>
				<p class="about-card-text">
					Explore real-time data and actionable insights that empower businesses and individuals to make informed decisions for a circular economy.
				</p>
			</div>
			<div class="about-card">
				<div class="about-card-icon">
					<Globe size={32} />
				</div>
				<h3 class="about-card-title">National Reach</h3>
				<p class="about-card-text">
					We are expanding our footprint across the continent, combining grassroots efforts with broad scale public resources for a greener Australia.
				</p>
			</div>
		</div>

		<h2 class="section-heading">What We Offer</h2>
		<div class="features-list">
			<div class="feature-item">
				<div class="feature-icon">
					<Search size={36} />
				</div>
				<div class="feature-content">
					<h3 class="feature-title">Item Search</h3>
					<p class="feature-description">
						Search for specific items to learn how to recycle them properly. Get detailed information about materials, 
						components, and disposal methods.
					</p>
				</div>
			</div>
			<div class="feature-item">
				<div class="feature-icon">
					<Map size={36} />
				</div>
				<div class="feature-content">
					<h3 class="feature-title">Location Finder</h3>
					<p class="feature-description">
						Discover recycling centers, drop-off locations, and specialized facilities near you. View hours, accepted 
						materials, and directions.
					</p>
				</div>
			</div>
			<div class="feature-item">
				<div class="feature-icon">
					<BarChart3 size={36} />
				</div>
				<div class="feature-content">
					<h3 class="feature-title">Impact Calculator</h3>
					<p class="feature-description">
						See the real-world impact of your recycling efforts. Calculate energy saved, emissions reduced, and resources 
						conserved through proper recycling.
					</p>
				</div>
			</div>
			<div class="feature-item">
				<div class="feature-icon">
					<Target size={36} />
				</div>
				<div class="feature-content">
					<h3 class="feature-title">Knowledge Quiz</h3>
					<p class="feature-description">
						Test your recycling knowledge and learn best practices. Compare your results with the community and discover 
						areas for improvement.
					</p>
				</div>
			</div>
		</div>

		<h2 class="section-heading">Join Our Community</h2>
		<p class="section-text">
			WasteWise is more than a tool—it's a community of people committed to making a difference. Share your experiences, 
			participate in polls, and see how your efforts compare with others working toward the same goal.
		</p>
		<p class="section-text">
			Together, we can create a cleaner, more sustainable future. Every piece of knowledge shared and every item recycled 
			correctly brings us closer to that vision.
		</p>
	</section>
</BaseLayout>

<style>
	.section-heading {
		font-size: clamp(26px, 3.5vw, 42px);
		font-weight: 700;
		color: var(--ink);
		margin: 48px auto 20px;
		font-family: var(--font-body);
		text-align: center;
	}

	.section-heading:first-of-type {
		margin-top: 0;
	}

	.section-text {
		font-size: 17px;
		line-height: 1.7;
		color: rgba(11, 19, 32, 0.8);
		margin: 0 auto 16px;
		font-weight: 400;
		text-align: center;
		max-width: 800px;
	}

	.about-grid {
		max-width: 1400px;
		margin: 32px auto;
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
	}

	.about-card {
		background: var(--glass);
		border: 1px solid var(--glass-border);
		border-radius: 16px;
		padding: 20px 22px;
		box-shadow: 0 10px 18px rgba(10, 16, 28, 0.06);
		text-align: center;
	}

	.about-card-icon {
		color: var(--green-2);
		margin: 0 auto 12px;
		display: flex;
		align-items: center;
		justify-content: center;
		width: 48px;
		height: 48px;
		background: rgba(102, 194, 74, 0.1);
		border-radius: 12px;
	}

	.about-card-title {
		margin: 0 0 8px;
		font-size: 18px;
		color: rgba(11, 19, 32, 0.9);
		font-weight: 700;
		text-align: center;
	}

	.about-card-text {
		margin: 0;
		font-weight: 400;
		color: rgba(11, 19, 32, 0.72);
		line-height: 1.5;
		font-size: 15px;
		text-align: center;
	}

	.features-list {
		display: flex;
		flex-direction: column;
		gap: 20px;
		margin: 32px auto;
		max-width: 1400px;
	}

	.feature-item {
		display: grid;
		grid-template-columns: 60px 1fr;
		gap: 20px;
		padding: 24px;
		background: var(--glass);
		border: 1px solid var(--glass-border);
		border-radius: 16px;
		box-shadow: 0 4px 12px rgba(10, 16, 28, 0.04);
		transition: transform 0.2s, box-shadow 0.2s;
		text-align: left;
	}

	.feature-item:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 20px rgba(10, 16, 28, 0.08);
	}

	.feature-icon {
		color: var(--green-2);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.feature-content {
		display: flex;
		flex-direction: column;
		gap: 8px;
	}

	.feature-title {
		margin: 0;
		font-size: 20px;
		font-weight: 700;
		color: var(--ink);
	}

	.feature-description {
		margin: 0;
		font-size: 15px;
		line-height: 1.6;
		color: rgba(11, 19, 32, 0.75);
		font-weight: 400;
	}

	@media (max-width: 860px) {
		.about-grid {
			grid-template-columns: 1fr;
		}

		.feature-item {
			grid-template-columns: 1fr;
			text-align: center;
		}

		.feature-icon {
			justify-content: center;
		}
	}
</style>
