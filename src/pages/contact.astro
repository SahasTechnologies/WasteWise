---
import BaseLayout from '../components/BaseLayout.astro';
import { CheckCircle } from '@lucide/astro';
---

<BaseLayout title="Contact | WasteWise">
	<section class="simple-section simple-section-centered">
		<div id="form-view" class="contact-container">
			<h1 class="simple-title">Contact Us</h1>
			<p class="simple-subtitle">We'd love to hear from you. Fill out the form below.</p>

			<p class="email-alt-hint">
				Don't want to contact us by this form? You can also email us here:
				<button class="email-reveal-btn" id="open-email-popup" type="button">See email address</button>
			</p>

			<form class="contact-form" id="native-contact">
				<input type="hidden" name="_subject" value="New WasteWise Contact Form Message" />
				<input type="hidden" name="User IP" id="user-ip-field" value="unknown" />
				<input type="hidden" name="City" id="user-city-field" value="unknown" />
				<input type="hidden" name="ISP" id="user-isp-field" value="unknown" />

				<div class="form-group">
					<label class="form-label" for="contact-name">Name</label>
					<input
						class="form-input"
						type="text"
						id="contact-name"
						name="Name"
						placeholder="Your name"
						required
					/>
				</div>

				<div class="form-group">
					<label class="form-label" for="contact-email">Email</label>
					<input
						class="form-input"
						type="email"
						id="contact-email"
						name="Email"
						placeholder="your@email.com"
						required
					/>
				</div>

				<div class="form-group">
					<label class="form-label" for="contact-message">Message</label>
					<textarea
						class="form-input form-textarea"
						id="contact-message"
						name="Message"
						placeholder="Type your message here…"
						rows="5"
						required
					></textarea>
				</div>

				<div class="cf-turnstile" data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITEKEY} data-theme="light"></div>
				<br/>

				<button type="submit" class="go contact-submit">Send Message</button>
			</form>
		</div>

		<div id="success-view" class="contact-container hidden">
			<div class="success-icon-wrap">
				<CheckCircle size={64} />
			</div>
			<h1 class="header-title">Message Sent!</h1>
			<p class="header-subtitle">Thank you for contacting us. We will get back to you shortly.</p>
			<a href="/" class="go">Return Home</a>
		</div>
	</section>

	<div id="email-popup-overlay" class="popup-overlay hidden" role="dialog" aria-modal="true" aria-labelledby="popup-title">
		<div class="popup-box">
			<button class="popup-close" id="close-email-popup" aria-label="Close">&times;</button>
			<h2 class="popup-title" id="popup-title">Verify to see our email</h2>
			<p class="popup-subtitle">Complete the quick check below to reveal our email address.</p>

			<div id="email-turnstile-widget" class="email-turnstile-container cf-turnstile"
				data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITEKEY}
				data-theme="light"
				data-callback="onEmailTurnstileSuccess"
			></div>

			<div id="email-reveal" class="email-reveal hidden">
				<p class="email-reveal-text">Message us via</p>
				<a href="#" id="email-reveal-address" class="email-reveal-address">Loading...</a>
			</div>
		</div>
	</div>
</BaseLayout>

<script src="../scripts/contact.js"></script>
<script src="../scripts/contact-form.js"></script>
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
