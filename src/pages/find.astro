---
import { Search, MapPin, Trash2, Loader2 } from '@lucide/astro';
import BaseLayout from '../components/BaseLayout.astro';
---

<BaseLayout title="Find Recycling Locations | WasteWise">
	<Fragment slot="head">
		<link
			rel="stylesheet"
			href="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.css"
			integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
			crossorigin=""
		/>
		<script
			src="https://cdn.jsdelivr.net/npm/leaflet@1.9.4/dist/leaflet.js"
			integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
			crossorigin=""
		></script>
	</Fragment>

	<section class="recyclemate-section">
		<h1 class="simple-title">Find Recycling Locations</h1>
		<p class="simple-subtitle">Search for items and find where to recycle them near you</p>

		<div class="recyclemate-search-container">
			<div class="search-input-group">
				<input 
					type="text" 
					id="address-input" 
					placeholder="Enter your address" 
					class="search-input"
					autocomplete="off"
				/>
				<Loader2 id="address-loading" class="autocomplete-loading hidden" size={20} />
				<div id="address-suggestions" class="autocomplete-suggestions"></div>
			</div>

			<div class="search-input-group">
				<input 
					type="text" 
					id="item-input" 
					placeholder="What do you want to recycle?" 
					class="search-input"
					autocomplete="off"
				/>
				<Loader2 id="item-loading" class="autocomplete-loading hidden" size={20} />
				<div id="item-suggestions" class="autocomplete-suggestions"></div>
			</div>

			<button id="search-btn" class="go search-btn">
				<Search size={20} />
				Search
			</button>
		</div>

		<div id="results-container" class="results-container find-results-container hidden">
			<div id="item-info" class="item-info"></div>
			
			<div class="results-layout">
				<div id="locations-list" class="locations-list"></div>
				<div id="map-container" class="map-container">
					<div id="map" class="recyclemate-map"></div>
				</div>
			</div>
		</div>

		<div class="recyclemate-attribution">
			Information from <a href="https://recyclemate.com.au" target="_blank" rel="noopener noreferrer">RecycleMate</a>
		</div>
	</section>

	<script src="../scripts/recyclemate.js"></script>
</BaseLayout>
