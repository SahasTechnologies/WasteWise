---
import BaseLayout from '../layouts/BaseLayout.astro';
import answersData from '../data/answers.json';

---

<BaseLayout title="Quiz Results | WasteWise">
    <section class="simple-section results-container">
        <h1 class="simple-title tight results-title">Quiz Results</h1>
        <p class="simple-subtitle results-score" id="score-display">
            Calculating score...
        </p>

        <div class="questions-list" id="questions-container" data-answers={JSON.stringify(answersData)}>
            {answersData.map((question) => {
                return (
                    <div class="question-block" data-question-id={question.id}>
                        <h3>{question.id}. {question.question}</h3>
                        
                        <div class="options">
                            {Object.entries(question.options).map(([letter, text]) => {
                                return (
                                    <div class="option" data-letter={letter}>
                                        <div class="option-label option-label-styled">
                                            {letter}
                                        </div>
                                        <div class="option-body">
                                            <div class="option-text">{text}</div>
                                            <div class="option-status-container"></div>
                                            
                                            <div class="explanation explanation-hidden">
                                                <strong>Explanation:</strong> {question.explanations[letter as keyof typeof question.explanations]}
                                            </div>
                                        </div>
                                    </div>
                                );
                            })}
                        </div>
                    </div>
                )
            })}
        </div>
        
        <div class="results-actions">
            <a href="/quiz?retry=true" class="go">Retake Quiz</a>
        </div>
    </section>
</BaseLayout>

<script>
    import '../scripts/answers.js';
</script>
