---
import BaseLayout from '../components/BaseLayout.astro';
import answersData from '../data/answers.json';
import { Trophy, Star } from '@lucide/astro';
---

<BaseLayout title="Quiz | WasteWise">
	<section class="quiz-section">
		<!-- Progress bar -->
		<div class="quiz-progress-wrap" aria-label="Quiz progress">
			<div class="quiz-progress-bar" id="quiz-progress-bar" style="width: 0%"></div>
		</div>

		<!-- Question step container -->
		<div class="quiz-stage" id="quiz-stage" data-total={answersData.length}>
			{answersData.map((q, index) => (
				<div class={`quiz-step ${index === 0 ? '' : 'hidden'}`} id={`quiz-step-${index}`} data-correct={q.correctAnswer}>
					<p class="quiz-step-counter">{index + 1} / {answersData.length}</p>
					<h2 class="quiz-question-text">{q.question}</h2>
					<div class="quiz-options" role="list" id={`quiz-options-${index}`}>
						{Object.entries(q.options).map(([letter, text]) => (
							<button
								class={`quiz-option option-btn-${index}`}
								data-letter={letter}
								data-text={text}
								role="listitem"
								aria-label={`Option ${letter}: ${text}`}
							>
								<span class="quiz-option-label">{letter}</span>
								<span class="quiz-option-text">{text}</span>
							</button>
						))}
					</div>
					<div class="quiz-explanation hidden" id={`explanation-${index}`}>
						<p class="quiz-explanation-text" id={`explanation-text-${index}`}></p>
					</div>
					<div class="quiz-next-wrap hidden" id={`next-wrap-${index}`}>
						<button class="go quiz-next-btn" id={`next-btn-${index}`}>
							{index === answersData.length - 1 ? 'See Results' : 'Next →'}
						</button>
					</div>
                    <div id={`expl-data-${index}`} class="hidden" data-explanations={JSON.stringify(q.explanations)}></div>
				</div>
			))}
		</div>

		<!-- Score screen (hidden until end) -->
		<div class="quiz-score-screen hidden" id="quiz-score-screen">
			<div class="score-inner">
				<div class="score-icon" id="score-icon">
					<div class="icon-trophy hidden">
						<Trophy size={64} />
					</div>
					<div class="icon-star">
						<Star size={64} />
					</div>
				</div>
				<h1 class="score-title">Quiz Complete!</h1>
				<p class="score-value" id="score-value">You got 0/10 correct</p>
				<p class="score-sub" id="score-sub"></p>
				
				<!-- Results Distribution Chart -->
				<div class="quiz-results-chart" id="quiz-results-chart">
					<h3 class="chart-title">How Others Scored</h3>
					<div class="chart-bars">
						<div class="chart-bar-group">
							<div class="chart-bar-wrapper">
								<div class="chart-bar" id="bar-1" style="height: 0%"></div>
							</div>
							<span class="chart-label">1/10</span>
							<span class="chart-count" id="count-1">0</span>
						</div>
						<div class="chart-bar-group">
							<div class="chart-bar-wrapper">
								<div class="chart-bar" id="bar-2" style="height: 0%"></div>
							</div>
							<span class="chart-label">2/10</span>
							<span class="chart-count" id="count-2">0</span>
						</div>
						<div class="chart-bar-group">
							<div class="chart-bar-wrapper">
								<div class="chart-bar" id="bar-3" style="height: 0%"></div>
							</div>
							<span class="chart-label">3/10</span>
							<span class="chart-count" id="count-3">0</span>
						</div>
						<div class="chart-bar-group">
							<div class="chart-bar-wrapper">
								<div class="chart-bar" id="bar-4" style="height: 0%"></div>
							</div>
							<span class="chart-label">4/10</span>
							<span class="chart-count" id="count-4">0</span>
						</div>
						<div class="chart-bar-group">
							<div class="chart-bar-wrapper">
								<div class="chart-bar" id="bar-5" style="height: 0%"></div>
							</div>
							<span class="chart-label">5/10</span>
							<span class="chart-count" id="count-5">0</span>
						</div>
						<div class="chart-bar-group">
							<div class="chart-bar-wrapper">
								<div class="chart-bar" id="bar-6" style="height: 0%"></div>
							</div>
							<span class="chart-label">6/10</span>
							<span class="chart-count" id="count-6">0</span>
						</div>
						<div class="chart-bar-group">
							<div class="chart-bar-wrapper">
								<div class="chart-bar" id="bar-7" style="height: 0%"></div>
							</div>
							<span class="chart-label">7/10</span>
							<span class="chart-count" id="count-7">0</span>
						</div>
						<div class="chart-bar-group">
							<div class="chart-bar-wrapper">
								<div class="chart-bar" id="bar-8" style="height: 0%"></div>
							</div>
							<span class="chart-label">8/10</span>
							<span class="chart-count" id="count-8">0</span>
						</div>
						<div class="chart-bar-group">
							<div class="chart-bar-wrapper">
								<div class="chart-bar" id="bar-9" style="height: 0%"></div>
							</div>
							<span class="chart-label">9/10</span>
							<span class="chart-count" id="count-9">0</span>
						</div>
						<div class="chart-bar-group">
							<div class="chart-bar-wrapper">
								<div class="chart-bar" id="bar-10" style="height: 0%"></div>
							</div>
							<span class="chart-label">10/10</span>
							<span class="chart-count" id="count-10">0</span>
						</div>
					</div>
				</div>
				
				<button class="go quiz-retake" id="quiz-retake">Retake Quiz</button>
			</div>
		</div>
	</section>
</BaseLayout>

<script src="../scripts/quiz.js"></script>