---
import { Github, Recycle } from '@lucide/astro';

// Fetch the current year dynamically
let currentYear = new Date().getFullYear();
try {
    const response = await fetch('https://api.datesapi.net/today');
    if (response.ok) {
        const data = await response.json();
        // data.result is in format YYYY-MM-DD
        if (data && data.result) {
            currentYear = data.result.split('-')[0];
        }
    }
} catch (error) {
    console.error("Failed to fetch date:", error);
}

---

<footer class="footer" aria-label="WasteWise Footer">
    <div class="footer-inner">
        <div class="footer-brand">
            <a href="/" class="brand-link" aria-label="WasteWise Home">
                <Recycle class="footer-icon" aria-hidden="true" />
                <span class="footer-title">WasteWise</span>
            </a>
            <p class="footer-text">Recycling made easy for everyone.</p>
        </div>
        
        <div class="footer-links">
            <div class="link-group">
                <a href="/quiz" class="footer-link">Quiz</a>
                <a href="/articles" class="footer-link">Articles</a>
                <a href="/about" class="footer-link">About</a>
                <a href="/contact" class="footer-link">Contact</a>
            </div>
        </div>
    </div>
    <div class="footer-bottom">
        <p class="copyright">&copy; {currentYear} WasteWise. All rights reserved.</p>
        <div class="social-links">
            <a href="https://github.com/SahasTechnologies/WasteWise" aria-label="GitHub"><Github class="social-icon" /></a>
        </div>
    </div>
</footer>

<style>
    .footer {
        background: #143321; /* Dark green belonging to the same palette */
        color: rgba(255, 255, 255, 0.7);
        padding: 64px var(--hero-inset) 24px;
        margin-top: 64px;
        border-radius: 18px 18px 0 0;
        font-family: inherit;
    }

    .footer-inner {
        max-width: var(--page-max);
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        padding-bottom: 48px;
        padding-left: 32px;
        padding-right: 32px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .footer-brand {
        max-width: 380px;
    }

    .brand-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #ffffff;
        text-decoration: none;
        font-size: 20px;
        font-weight: 700;
        margin-bottom: 16px;
    }

    .footer-icon {
        width: 24px;
        height: 24px;
        color: var(--green-1);
    }

    .footer-text {
        font-size: 15px;
        line-height: 1.6;
        margin: 0;
        font-weight: 400;
    }

    .footer-links {
        display: flex;
        gap: 64px;
        justify-content: flex-start;
        padding-left: 64px;
    }

    .link-group {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .footer-link {
        color: rgba(255, 255, 255, 0.6);
        text-decoration: none;
        font-size: 14px;
        transition: color 0.2s;
        font-weight: 400;
    }

    .footer-link:hover {
        color: var(--green-1);
    }

    .footer-bottom {
        max-width: var(--page-max);
        margin: 24px auto 0;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .copyright {
        margin: 0;
        font-size: 14px;
        font-weight: 400;
    }

    .social-links {
        display: flex;
        gap: 16px;
    }

    .social-icon {
        width: 20px;
        height: 20px;
        color: rgba(255, 255, 255, 0.6);
        transition: color 0.2s;
    }

    .social-icon:hover {
        color: #ffffff;
    }

    @media (max-width: 768px) {
        .footer-inner {
            grid-template-columns: 1fr;
            gap: 40px;
        }

        .footer-links {
            justify-content: flex-start;
            flex-wrap: wrap;
        }

        .footer-bottom {
            flex-direction: column;
            gap: 16px;
            text-align: center;
        }
    }
</style>
