---
import { Apple, Package, Droplet, Wine, Soup, Leaf, Globe, Car, Lightbulb, Smartphone, AlertTriangle } from '@lucide/astro';
---
<section class="home-stats" aria-labelledby="stats-heading">
  <div class="stats-container">
    <h2 id="stats-heading" class="stats-title">Your small actions can reduce waste for good</h2>
    
    <div class="stats-widgets">
      <!-- First counter (Tonnes of waste from households) -->
      <div class="stat-widget static-stat">
        <div class="stat-value"><span id="world-count-1">Loading...</span></div>
        <div class="stat-label">Tonnes of waste from households (Globally, this year)</div>
        <div class="stats-source">
            <a href="https://www.theworldcounts.com/challenges/waste/waste-from-households" target="_blank" rel="noopener noreferrer">The World Counts</a>
        </div>
      </div>

      <!-- Middle static stat -->
      <div class="stat-widget static-stat">
        <div class="stat-value">~1,500 <span class="stat-unit">Tonnes</span></div>
        <div class="stat-label">Daily Sydney Household Waste Generation</div>
        <div class="stats-source">
            <a href="https://data.nsw.gov.au" target="_blank" rel="noopener noreferrer">data.nsw.gov.au</a>
        </div>
      </div>

      <!-- Third counter (Tonnes of waste dumped) -->
      <div class="stat-widget static-stat">
        <div class="stat-value"><span id="world-count-2">Loading...</span></div>
        <div class="stat-label">Tonnes of waste dumped (Globally, this year)</div>
        <div class="stats-source">
            <a href="https://www.theworldcounts.com/challenges/waste/global-waste-problem" target="_blank" rel="noopener noreferrer">The World Counts</a>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Separate Impact Calculator Section -->
<section class="impact-calculator-section" aria-labelledby="impact-heading">
  <div class="impact-calculator-inner">
    <h2 id="impact-heading" class="impact-calc-title">See Your Recycling Impact</h2>
    <p class="impact-calc-subtitle">Adjust the sliders to match your bin's contents — see how much CO₂ you save by recycling</p>

    <div class="impact-bin-top">
      <div class="impact-bin-info">
        <span class="impact-bin-label">Total bin weight</span>
        <span class="impact-bin-kg" id="total-kg-display">20 kg</span>
      </div>
      <button class="impact-reset-btn" id="impact-reset-btn" type="button">Reset to default bin</button>
    </div>

    <!-- Material sliders -->
    <div class="material-sliders" id="material-sliders">
      <div class="material-slider-row" data-material="food_waste">
        <div class="material-slider-header">
          <span class="material-icon-wrap"><Apple size={20} /></span>
          <span class="material-name">Food Waste</span>
          <span class="material-pct" id="pct-food_waste">50%</span>
        </div>
        <div class="material-slider-track-wrap">
          <input type="range" min="0" max="100" value="50" class="material-range" id="slider-food_waste" data-key="food_waste" aria-label="Food waste percentage" />
          <div class="slider-labels-small">
            <span>0%</span>
            <span>100%</span>
          </div>
        </div>
      </div>

      <div class="material-slider-row" data-material="paper_cardboard">
        <div class="material-slider-header">
          <span class="material-icon-wrap"><Package size={20} /></span>
          <span class="material-name">Paper &amp; Cardboard</span>
          <span class="material-pct" id="pct-paper_cardboard">23%</span>
        </div>
        <div class="material-slider-track-wrap">
          <input type="range" min="0" max="100" value="23" class="material-range" id="slider-paper_cardboard" data-key="paper_cardboard" aria-label="Paper and cardboard percentage" />
          <div class="slider-labels-small">
            <span>0%</span>
            <span>100%</span>
          </div>
        </div>
      </div>

      <div class="material-slider-row" data-material="plastics">
        <div class="material-slider-header">
          <span class="material-icon-wrap"><Droplet size={20} /></span>
          <span class="material-name">Plastics</span>
          <span class="material-pct" id="pct-plastics">13%</span>
        </div>
        <div class="material-slider-track-wrap">
          <input type="range" min="0" max="100" value="13" class="material-range" id="slider-plastics" data-key="plastics" aria-label="Plastics percentage" />
          <div class="slider-labels-small">
            <span>0%</span>
            <span>100%</span>
          </div>
        </div>
      </div>

      <div class="material-slider-row" data-material="glass">
        <div class="material-slider-header">
          <span class="material-icon-wrap"><Wine size={20} /></span>
          <span class="material-name">Glass</span>
          <span class="material-pct" id="pct-glass">2%</span>
        </div>
        <div class="material-slider-track-wrap">
          <input type="range" min="0" max="100" value="2" class="material-range" id="slider-glass" data-key="glass" aria-label="Glass percentage" />
          <div class="slider-labels-small">
            <span>0%</span>
            <span>100%</span>
          </div>
        </div>
      </div>

      <div class="material-slider-row" data-material="metals">
        <div class="material-slider-header">
          <span class="material-icon-wrap"><Soup size={20} /></span>
          <span class="material-name">Metals</span>
          <span class="material-pct" id="pct-metals">4%</span>
        </div>
        <div class="material-slider-track-wrap">
          <input type="range" min="0" max="100" value="4" class="material-range" id="slider-metals" data-key="metals" aria-label="Metals percentage" />
          <div class="slider-labels-small">
            <span>0%</span>
            <span>100%</span>
          </div>
        </div>
      </div>

      <div class="material-slider-row" data-material="garden_waste">
        <div class="material-slider-header">
          <span class="material-icon-wrap"><Leaf size={20} /></span>
          <span class="material-name">Garden Waste</span>
          <span class="material-pct" id="pct-garden_waste">8%</span>
        </div>
        <div class="material-slider-track-wrap">
          <input type="range" min="0" max="100" value="8" class="material-range" id="slider-garden_waste" data-key="garden_waste" aria-label="Garden waste percentage" />
          <div class="slider-labels-small">
            <span>0%</span>
            <span>100%</span>
          </div>
        </div>
      </div>
    </div>

    <div class="pct-warning hidden" id="pct-warning">
      <AlertTriangle size={16} style="display: inline; vertical-align: middle; margin-right: 4px;" />
      Percentages must add to 100%. Currently at <strong id="pct-total-val">100</strong>%
    </div>

    <!-- CO2 Savings Results -->
    <div class="impact-results-new" id="impact-results-new">
      <h3 class="impact-results-title">Recycling this bin saves approximately:</h3>
      <div class="impact-results-grid">
        <div class="impact-result-card">
          <span class="impact-result-icon"><Globe size={28} /></span>
          <span class="impact-result-value" id="res-co2">0.0</span>
          <span class="impact-result-unit">kg CO₂ saved</span>
        </div>
        <div class="impact-result-card">
          <span class="impact-result-icon"><Car size={28} /></span>
          <span class="impact-result-value" id="res-car">0.0</span>
          <span class="impact-result-unit">km not driven</span>
        </div>
        <div class="impact-result-card">
          <span class="impact-result-icon"><Lightbulb size={28} /></span>
          <span class="impact-result-value" id="res-led">0</span>
          <span class="impact-result-unit">hours of LED light</span>
        </div>
        <div class="impact-result-card">
          <span class="impact-result-icon"><Smartphone size={28} /></span>
          <span class="impact-result-value" id="res-phone">0</span>
          <span class="impact-result-unit">phone charges</span>
        </div>
      </div>
      <p class="impact-source-note">
        Based on Australian recycling emissions data &amp; <a href="https://data.nsw.gov.au" target="_blank" rel="noopener noreferrer">NSW EPA averages</a>. Default bin composition from <a href="https://www.dcceew.gov.au/environment/protection/waste/publications/national-waste-reports" target="_blank" rel="noopener noreferrer">DCCEEW National Waste Report</a>.
      </p>
    </div>
  </div>
</section>

<script src="../scripts/impact-stats.js"></script>
